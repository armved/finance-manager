# Copy this file to .env and fill in values before deploying via Coolify.
# Never commit .env to git.

# PostgreSQL connection string — copy from Coolify's database resource page
DATABASE_URL=postgresql://user:password@host:5432/finance_manager

# Allowed CORS origin. Use * for local network access, or set to the exact
# URL you use to open the app (e.g. http://192.168.1.100:3000)
CORS_ORIGIN=*

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Port the web app will be accessible on (default: 3000)
WEB_PORT=3000
